<RadioGroup
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/vibration_pattern_radio_group"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <RadioButton
        android:id="@+id/vibration_pattern_default"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/vibration_pattern_default_title" />

    <RadioButton
        android:id="@+id/vibration_pattern_soft"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/vibration_pattern_soft_title" />

    <RadioButton
        android:id="@+id/vibration_pattern_strong"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/vibration_pattern_strong_title" />

    <RadioButton
        android:id="@+id/vibration_pattern_heartbeat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/vibration_pattern_heartbeat_title" />

    <RadioButton
        android:id="@+id/vibration_pattern_escalating"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/vibration_pattern_escalating_title" />

    <RadioButton
        android:id="@+id/vibration_pattern_tick_tock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/vibration_pattern_tick_tock_title" />

</RadioGroup>
